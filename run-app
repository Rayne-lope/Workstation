#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
DERIVED_DATA_PATH="$ROOT_DIR/.derivedData"
APP_PATH="$DERIVED_DATA_PATH/Build/Products/Debug/Workstation.app"
RELEASE_APP_PATH="$DERIVED_DATA_PATH/Build/Products/Release/Workstation.app"
INSTALL_PATH="/Applications/Workstation.app"
PROJECT_PATH="$ROOT_DIR/Workstation.xcodeproj"
SCHEME="Workstation"
BUILD_LOG="$ROOT_DIR/.build.log"

usage() {
  cat <<'EOF'
Usage:
  ./run-app              Build (Debug) and open the app
  ./run-app build        Build only (Debug)
  ./run-app run          Build (Debug) and open the app
  ./run-app release      Build Release + install to /Applications/Workstation.app
  ./run-app logs         Show last build log
EOF
}

draw_progress() {
  local percent="$1"
  local label="$2"
  local width=28
  local filled=$((percent * width / 100))
  local empty=$((width - filled))

  local bar=""
  for ((i = 0; i < filled; i++)); do bar="${bar}█"; done
  for ((i = 0; i < empty; i++)); do bar="${bar}░"; done

  printf "\r\033[K🚀 Building Workstation [%s] %3d%%  %s" "$bar" "$percent" "$label"
}

update_progress_from_log() {
  local current="$1"
  local next="$current"
  local label="Building"

  if [[ ! -f "$BUILD_LOG" ]]; then
    echo "$next|Preparing"
    return
  fi

  if grep -q "CompileSwiftSources\|CompileSwift\|SwiftCompile" "$BUILD_LOG"; then
    label="Compiling Swift"
    (( next < 55 )) && next=$((next + 2))
  elif grep -q "Ld \|LinkStoryboards" "$BUILD_LOG"; then
    label="Linking"
    (( next < 75 )) && next=$((next + 2))
  elif grep -q "ProcessInfoPlistFile" "$BUILD_LOG"; then
    label="Processing Info.plist"
    (( next < 82 )) && next=$((next + 1))
  elif grep -q "CodeSign" "$BUILD_LOG"; then
    label="Code signing"
    (( next < 92 )) && next=$((next + 1))
  elif grep -q "Validate" "$BUILD_LOG"; then
    label="Validating"
    (( next < 96 )) && next=$((next + 1))
  else
    label="Preparing"
    (( next < 35 )) && next=$((next + 1))
  fi

  (( next > 96 )) && next=96
  echo "$next|$label"
}

release_app() {
  rm -f "$BUILD_LOG"

  printf "\033[?25l"
  trap 'printf "\033[?25h\n"' EXIT

  draw_progress 0 "Preparing (Release)"

  set +e
  (
    xcodebuild \
      -project "$PROJECT_PATH" \
      -scheme "$SCHEME" \
      -configuration Release \
      -derivedDataPath "$DERIVED_DATA_PATH" \
      build
  ) > "$BUILD_LOG" 2>&1 &

  local build_pid=$!
  local percent=1

  while kill -0 "$build_pid" 2>/dev/null; do
    IFS="|" read -r percent label <<< "$(update_progress_from_log "$percent")"
    draw_progress "$percent" "$label"
    sleep 0.2
  done

  wait "$build_pid"
  local status=$?
  set -e

  if [[ "$status" -ne 0 ]]; then
    printf "\n❌ Build failed\n\n"
    tail -n 60 "$BUILD_LOG"
    exit "$status"
  fi

  draw_progress 100 "Done"
  printf "\n"

  # Re-sign with a real ad-hoc signature, specifying entitlements for the main app and widget individually to prevent stripping.
  if codesign --force --sign - --entitlements "$ROOT_DIR/WorkstationWidget/WorkstationWidget.entitlements" "$RELEASE_APP_PATH/Contents/PlugIns/WorkstationWidget.appex" >/dev/null 2>&1 && \
     codesign --force --sign - --entitlements "$ROOT_DIR/App/Workstation.entitlements" "$RELEASE_APP_PATH" >/dev/null 2>&1; then
    printf "🔏 Code-signed (ad-hoc)\n"
  else
    printf "⚠️  Code-sign step failed (notifications/widgets may not work)\n"
  fi

  # Install / replace /Applications/Workstation.app
  printf "📦 Installing to %s..." "$INSTALL_PATH"
  rm -rf "$INSTALL_PATH"
  cp -R "$RELEASE_APP_PATH" "$INSTALL_PATH"
  local size
  size=$(du -sh "$INSTALL_PATH" | cut -f1)
  printf "\r✅ Installed %s → %s\n" "$size" "$INSTALL_PATH"
  printf "   Run: open /Applications/Workstation.app\n"
}

build_app() {
  rm -f "$BUILD_LOG"

  printf "\033[?25l" # hide cursor
  trap 'printf "\033[?25h\n"' EXIT

  draw_progress 0 "Preparing"

  set +e

  # Important:
  # Everything from xcodebuild goes to BUILD_LOG.
  # Terminal only shows our progress UI.
  (
    xcodebuild \
      -project "$PROJECT_PATH" \
      -scheme "$SCHEME" \
      -configuration Debug \
      -derivedDataPath "$DERIVED_DATA_PATH" \
      build
  ) > "$BUILD_LOG" 2>&1 &

  local build_pid=$!
  local percent=1
  local label="Preparing"

  while kill -0 "$build_pid" 2>/dev/null; do
    IFS="|" read -r percent label <<< "$(update_progress_from_log "$percent")"
    draw_progress "$percent" "$label"
    sleep 0.2
  done

  wait "$build_pid"
  local status=$?

  set -e

  if [[ "$status" -eq 0 ]]; then
    draw_progress 100 "Done"
    printf "\n✅ Build succeeded\n"
    # Re-sign with a real ad-hoc signature. Xcode leaves the binary "linker-signed"
    # (CODE_SIGNING_ALLOWED=NO), which usernotificationsd/widgetkit reject.
    # Specify entitlements for the main app and widget individually to prevent stripping.
    if codesign --force --sign - --entitlements "$ROOT_DIR/WorkstationWidget/WorkstationWidget.entitlements" "$APP_PATH/Contents/PlugIns/WorkstationWidget.appex" >/dev/null 2>&1 && \
       codesign --force --sign - --entitlements "$ROOT_DIR/App/Workstation.entitlements" "$APP_PATH" >/dev/null 2>&1; then
      printf "🔏 Code-signed (ad-hoc)\n"
    else
      printf "⚠️  Code-sign step failed (notifications/widgets may not work)\n"
    fi
  else
    printf "\n❌ Build failed\n\n"
    echo "Last 100 lines from build log:"
    echo "────────────────────────────────────────"
    tail -n 100 "$BUILD_LOG"
    echo "────────────────────────────────────────"
    echo "Full log saved at: $BUILD_LOG"
    exit "$status"
  fi
}

mode="${1:-run}"

case "$mode" in
  build)
    build_app
    ;;
  run)
    build_app
    open "$APP_PATH"
    ;;
  release)
    release_app
    ;;
  logs)
    if [[ -f "$BUILD_LOG" ]]; then
      less "$BUILD_LOG"
    else
      echo "No build log found at: $BUILD_LOG"
      exit 1
    fi
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    echo "Unknown mode: $mode" >&2
    usage >&2
    exit 1
    ;;
esac